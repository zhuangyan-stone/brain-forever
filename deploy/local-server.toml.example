# ============================================================
# BrainForever local-server 部署配置文件示例
# 复制此文件到部署目录，按环境修改配置。
# API Key 等敏感信息请使用环境变量，不要写入此文件。
# ============================================================

[server]
# 服务标识，用于日志
name = "local-server"
# 本地监听地址
addr = ":8080"
# 以下超时配置单位为秒，0 表示不超时
read_timeout = 30
read_header_timeout = 10
# write_timeout 必须设为 0（不限时），因为 SSE 流式响应是长连接，
# LLM 流式输出可能持续数分钟（尤其是启用联网搜索 + 深度思考时）。
# 设为有限值会导致 SSE 写入超时，触发 i/o timeout 错误。
write_timeout = 0
idle_timeout = 60

[logger]
file = "log/local-server.log"
level = "INFO"

[data]
# 数据存储目录（SQLite 数据库文件存放位置）
dir = "./localdb"
brain_db = "brain.db"
users_db = "users.db"
anonymous_db = "anonymous.db"

[frontend]
# 前端静态文件目录
dir = "./frontend"
# 禁用浏览器缓存（开发环境使用）
cache_disable = false
