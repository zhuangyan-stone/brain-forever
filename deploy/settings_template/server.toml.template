# ============================================================
# BrainForever server 运行时配置模板
#
# 复制此文件到 bin/settings/server.toml 并按需修改配置项。
# 大部分配置项已有合理的默认值（定义在 cmd/server/main.go 中），
# 仅在此处列出需要显式关注的配置项。
#
# 敏感信息（数据库密码等）请使用环境变量传递，不要写入此文件！
# ============================================================

[server]
# 服务标识，用于日志
name = "brain-forever"
# 本地监听地址
addr = "[::]:8080"
# 以下超时配置单位为秒，0 表示不超时
read_timeout = 30
read_header_timeout = 10
# write_timeout 必须设为 0（不限时），因为 SSE 流式响应是长连接，
# LLM 流式输出可能持续数分钟（尤其是启用联网搜索 + 深度思考时）。
# 设为有限值会导致 SSE 写入超时，触发 i/o timeout 错误。
write_timeout = 0
idle_timeout = 60

[logger]
# 日志文件路径（留空则仅输出到 stdout）
file = "log/brain-forever.log"
# 日志级别：TRACE | DEBUG | INFO | WARN | ERROR | FATAL
level = "TRACE"

# ============================================================
# MySQL 数据库配置
# 用户数据（users 表）存储在 MySQL 中。
# 请通过环境变量 MYSQL_DSN_d2brain 设置连接字符串，格式：
#   MYSQL_DSN_d2brain="user:password@tcp(127.0.0.1:3306)/d2brain"
# 不要在此文件中写入密码！
# ============================================================
[database]
# MySQL 数据源名称（必须设置，否则程序无法启动）
# 或通过环境变量 MYSQL_DSN_d2brain 指定
dsn = ""

# ============================================================
# Redis 配置（可选）
# 启用后，登录状态将存储在 Redis 中，支持：
#   - 服务重启后保留登录态
#   - 多实例水平扩展
# 如果留空或 Redis 不可用，Session 管理降级为纯内存模式。
# ============================================================
[redis]
# Redis 服务器地址，如 "127.0.0.1:6379"
# 或通过环境变量 REDIS_ADDR 指定
addr = ""
# Redis 密码（如无认证则留空）
# 或通过环境变量 REDIS_PASSWORD 指定
password = ""

[data]
# 用户聊天/特征数据的 SQLite 存储目录
dir = "./localdb"

[frontend]
# 前端静态文件目录
dir = "./frontend"
# 禁用浏览器缓存（开发环境设为 true）
cache_disable = false
