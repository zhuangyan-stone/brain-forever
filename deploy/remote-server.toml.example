# ============================================================
# BrainForever remote-server 部署配置文件示例
# 复制此文件到部署目录，按环境修改配置。
# API Key 等敏感信息请使用环境变量，不要写入此文件。
# ============================================================

[server]
# 远程服务监听地址
addr = ":9090"

[logger]
file = "log/remote-server.log"
level = "INFO"
