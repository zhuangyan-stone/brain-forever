# ============================================================
# BrainForever local-server 运行时配置
# 此文件在运行过程中会被后端修改（如主题切换），
# 请勿提交到版本控制中（已在 .gitignore 中排除）。
# ============================================================

[theme]
# 当前激活的明暗模式: "light" | "dark"
actived = "dark"
# 用户选择的亮色主题 ID（空字符串表示使用内置亮色主题）
actived-light = "highcontrast-light"
# 用户选择的暗色主题 ID（空字符串表示使用内置暗色主题）
actived-dark = "highcontrast-dark"
